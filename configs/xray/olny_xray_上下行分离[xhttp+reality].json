{
  "log": {
    "access": "none",
    "error": "none",
    "loglevel": "warning",
    "dnsLog": true,
    "maskAddress": ""
  },
  "dns": {
    "hosts": {
      "domain:googleapis.cn": ["googleapis.com"],
      "dns.alidns.com": ["223.5.5.5", "223.6.6.6"]
    },
    "servers": [
      "https://8.8.8.8/dns-query",
      {
        "address": "https+local://dns.alidns.com/dns-query",
        "domains": [
          "geosite:private",
          "geosite:category-games@cn",
          "geosite:kaspersky",
          "domain:cf.godns.cc",
          "domain:cf.tencentapp.cn",
          "domain:cfyx.tencentapp.cn",
          "domain:1749991941.bilibiliapp.cn",
          "domain:freeyx.cloudflare88.eu.org",
          "domain:cfcn-a-proctusa.chinabaidu.pp.ua",
          "domain:dnew.cc",
          "domain:cloudflare.182682.xyz",
          "domain:baota.me",
          "domain:cloudflare-ip.mofashi.ltd"
        ],
        "skipFallback": true
      },
      {
        "address": "https://8.8.8.8/dns-query",
        "domains": ["geosite:geolocation-!cn"],
        "skipFallback": true
      },
      {
        "address": "https+local://dns.alidns.com/dns-query",
        "domains": ["geosite:cn"],
        "skipFallback": true
      }
    ],
    "tag": "dns-module",
    "queryStrategy": "UseIPv4",
    "useSystemHosts": false
  },
  "inbounds": [
    {
      "tag": "in-tun",
      "protocol": "tun",
      "settings": {
        "name": "xray0",
        "mtu": 1500,
        "gateway": ["10.0.0.1/16"],
        "dns": ["1.1.1.1", "1.0.0.1"],
        "autoSystemRoutingTable": ["0.0.0.0/0"],
        "autoOutboundsInterface": "auto"
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"],
        "metadataOnly": false,
        "routeOnly": true
      }
    }
  ],
  "outbounds": [
    {
      "tag": "out-proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "<VPS_IPv4>",
            "port": 443,
            "users": [
              {
                "id": "<XHTTP_UUID>",
                "flow": "",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "serverName": "<Reality_Site>",
          "fingerprint": "chrome",
          "password": "<Reality_publicKey>",
          "shortId": "<Reality_shortId>",
          "spiderX": "/",
          "show": false
        },
        "xhttpSettings": {
          "mode": "auto",
          "host": "",
          "path": "/<XHTTP_PATH>",
          "extra": {
            "downloadSettings": {
              "address": "[<VPS_IPv6>]",
              "port": 443,
              "network": "xhttp",
              "security": "reality",
              "realitySettings": {
                "serverName": "<Reality_Site>",
                "fingerprint": "chrome",
                "password": "<Reality_publicKey>",
                "shortId": "<Reality_shortId>",
                "spiderX": "/",
                "show": false
              },
              "xhttpSettings": {
                "mode": "auto",
                "host": "",
                "path": "/<XHTTP_PATH>"
              }
            }
          }
        }
      }
    },
    {
      "tag": "out-direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIPv4"
      }
    },
    {
      "tag": "out-block",
      "protocol": "blackhole"
    },
    {
      "tag": "out-dns",
      "protocol": "dns"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "inboundTag": ["in-tun"],
        "port": "53",
        "outboundTag": "out-dns"
      },
      {
        "inboundTag": ["dns-module"],
        "outboundTag": "out-proxy"
      },
      {
        "domain": ["geosite:private"],
        "outboundTag": "out-direct"
      },
      {
        "ip": ["ext:geoip-only-cn-private.dat:private"],
        "outboundTag": "out-direct"
      },
      {
        "network": "udp",
        "port": "443",
        "outboundTag": "out-block"
      },
      {
        "port": "853",
        "protocol": ["tls"],
        "outboundTag": "out-block"
      },
      {
        "domain": [
          "cf.godns.cc",
          "cf.tencentapp.cn",
          "cfyx.tencentapp.cn",
          "1749991941.bilibiliapp.cn",
          "freeyx.cloudflare88.eu.org",
          "cfcn-a-proctusa.chinabaidu.pp.ua",
          "dnew.cc",
          "cloudflare.182682.xyz",
          "baota.me",
          "cloudflare-ip.mofashi.ltd"
        ],
        "outboundTag": "out-direct"
      },
      {
        "protocol": ["bittorrent"],
        "outboundTag": "out-direct"
      },
      {
        "domain": ["geosite:category-games@cn"],
        "outboundTag": "out-direct"
      },
      {
        "domain": ["geosite:kaspersky"],
        "outboundTag": "out-direct"
      },
      {
        "domain": ["geosite:geolocation-!cn"],
        "outboundTag": "out-proxy"
      },
      {
        "domain": ["geosite:cn"],
        "outboundTag": "out-direct"
      },
      {
        "ip": ["ext:geoip-only-cn-private.dat:cn"],
        "outboundTag": "out-direct"
      }
    ]
  }
}
